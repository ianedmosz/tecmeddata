# ── Supabase ──────────────────────────────────────────────────────────────
# Dashboard de tu proyecto -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Solo se usa en el servidor (API routes) para crear usuarios desde el panel
# de administracion y para operaciones que necesitan saltar RLS. NUNCA se
# expone al cliente. Dashboard -> Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OCR (paso 1 del flujo de escaneo: imagen/PDF -> texto) ─────────────────
# Se necesita SOLO UNO de los dos. Si ninguno esta configurado, los botones
# "Escanear..." quedan deshabilitados y la app sigue funcionando con los
# formularios manuales (no se cae ninguna pantalla).
GOOGLE_CLOUD_VISION_API_KEY=
AWS_TEXTRACT_ACCESS_KEY_ID=
AWS_TEXTRACT_SECRET_ACCESS_KEY=
AWS_TEXTRACT_REGION=us-east-1

# ── LLM (paso 2 del flujo de escaneo: texto -> JSON estructurado) ──────────
# Se necesita SOLO UNO de los dos.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── App ──────────────────────────────────────────────────────────────────
# URL publica donde queda desplegada la app (usada por los QR que se generan
# para pegar en cada equipo). En local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
